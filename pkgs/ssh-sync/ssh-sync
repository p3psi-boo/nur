#!/usr/bin/env bash

# A script to synchronize local ~/.ssh/config and ~/.lazyssh/metadata.json with a GitHub Gist.
#
# Dependencies:
# - gh (GitHub CLI): For interacting with GitHub Gists.
# - jq: For parsing and manipulating JSON data.

set -euo pipefail

# --- Constants and Configuration ---
STATE_FILE="${HOME}/.config/ssh-sync/state.conf"
GIST_ID="" # This will be loaded from the state file.

# Local file paths
SSH_CONFIG_LOCAL_PATH="${HOME}/.ssh/config"
METADATA_LOCAL_PATH="${HOME}/.lazyssh/metadata.json"

# Filenames in the Gist
SSH_CONFIG_GIST_FILENAME="ssh_config"
METADATA_GIST_FILENAME="metadata-tags.json"

# --- Function Declarations ---

# Die with an error message.
die() {
  echo "ERROR: $*" >&2
  exit 1
}


# Check for required dependencies.
check_dependencies() {
  echo "Checking dependencies..."
  command -v gh >/dev/null || die "'gh' (GitHub CLI) is not installed. Please install it first."
  command -v jq >/dev/null || die "'jq' is not installed. Please install it first."
  echo "Dependencies are satisfied."
}

# Check if the user is authenticated with the GitHub CLI.
check_gh_auth() {
  echo "Checking GitHub authentication status..."
  if ! gh auth status &>/dev/null; then
    die "You are not logged in to GitHub. Please run 'gh auth login'."
  fi
  echo "Successfully authenticated with GitHub."
}

# Load Gist ID from the state file. If not found, prompt the user.
load_or_prompt_gist_id() {
  if [[ -f "$STATE_FILE" ]]; then
    GIST_ID=$(grep '^GIST_ID=' "$STATE_FILE" | cut -d'=' -f2)
  fi

  if [[ -z "$GIST_ID" ]]; then
    read -p "GitHub Gist ID not found. Please enter it now: " new_gist_id
    if [[ -z "$new_gist_id" ]]; then
      die "Gist ID cannot be empty."
    fi
    set_gist_id "$new_gist_id"
    GIST_ID="$new_gist_id"
  fi
}

# Save the Gist ID to the state file.
set_gist_id() {
  local new_gist_id="$1"
  mkdir -p "$(dirname "$STATE_FILE")"
  echo "GIST_ID=$new_gist_id" > "$STATE_FILE"
  echo "Gist ID saved to $STATE_FILE"
}

# Push content to a Gist file. Works for both creating and updating.
push_content_to_gist() {
  local content="$1"
  local gist_filename="$2"

  echo "Pushing content to Gist file: ${gist_filename}..."
  # Use gh api to PATCH the gist. This is the robust way to create/update a file.
  if ! gh api \
    --method PATCH \
    "/gists/${GIST_ID}" \
    -f "files[${gist_filename}][content]=${content}" > /dev/null; then
      die "Failed to push file '${gist_filename}' to Gist."
  fi
  echo "Push successful."
}

# Synchronize the ssh config file based on modification times.
sync_ssh_config() {
  echo "--- Syncing SSH Config (Auto-detecting direction) ---"

  # Get remote Gist details via the API
  local gist_details
  gist_details=$(gh api "/gists/${GIST_ID}" 2>/dev/null)
  if [[ -z "$gist_details" ]]; then
      die "Failed to fetch Gist details. Check Gist ID, network connection, and 'gh' auth status."
  fi

  # Check if the remote file exists in the Gist
  local remote_file_exists
  if echo "$gist_details" | jq -e ".files[\"${SSH_CONFIG_GIST_FILENAME}\"]" >/dev/null; then
    remote_file_exists=true
  else
    remote_file_exists=false
  fi

  # Case 1: Local file does not exist
  if [[ ! -f "${SSH_CONFIG_LOCAL_PATH}" ]]; then
    if [[ "$remote_file_exists" == true ]]; then
      echo "Local file not found. Pulling from Gist..."
      mkdir -p "$(dirname "${SSH_CONFIG_LOCAL_PATH}")"
      gh gist view "${GIST_ID}" --file "${SSH_CONFIG_GIST_FILENAME}" > "${SSH_CONFIG_LOCAL_PATH}"
      echo "Pull successful."
    else
      echo "Neither local nor remote SSH config exists. Nothing to sync."
    fi
    return
  fi

  # Case 2: Remote file does not exist
  if [[ "$remote_file_exists" == false ]]; then
    echo "Remote file not found. Pushing local file to Gist..."
    push_content_to_gist "$(cat "${SSH_CONFIG_LOCAL_PATH}")" "${SSH_CONFIG_GIST_FILENAME}"
    return
  fi

  # Case 3: Both exist, compare timestamps
  local remote_updated_at
  remote_updated_at=$(echo "$gist_details" | jq -r '.updatedAt')
  local remote_timestamp
  remote_timestamp=$(date -d "$remote_updated_at" +%s)
  
  local local_timestamp
  local_timestamp=$(stat -c %Y "${SSH_CONFIG_LOCAL_PATH}")

  if (( local_timestamp > remote_timestamp + 2 )); then # Add 2s buffer for clock drift/API lag
    echo "Local file is newer. Pushing to Gist..."
    push_content_to_gist "$(cat "${SSH_CONFIG_LOCAL_PATH}")" "${SSH_CONFIG_GIST_FILENAME}"
  elif (( remote_timestamp > local_timestamp + 2 )); then
    echo "Remote Gist is newer. Pulling from Gist..."
    mkdir -p "$(dirname "${SSH_CONFIG_LOCAL_PATH}")"
    gh gist view "${GIST_ID}" --file "${SSH_CONFIG_GIST_FILENAME}" > "${SSH_CONFIG_LOCAL_PATH}"
    echo "Pull successful."
  else
    echo "Local and remote SSH configs are already in sync."
  fi
}

# Synchronize the lazyssh metadata tags.
sync_metadata_tags() {
  echo "--- Syncing Lazyssh Metadata Tags ---"

  # Ensure local directory exists and the file is a valid JSON.
  mkdir -p "$(dirname "${METADATA_LOCAL_PATH}")"
  if [[ ! -f "${METADATA_LOCAL_PATH}" ]] || ! jq . "${METADATA_LOCAL_PATH}" &>/dev/null; then
    echo "Local metadata file is missing or invalid. Initializing with an empty JSON object."
    echo "{}" > "${METADATA_LOCAL_PATH}"
  fi

  # 1. Get remote tags from Gist.
  local remote_tags_json
  remote_tags_json=$(gh gist view "${GIST_ID}" --file "${METADATA_GIST_FILENAME}" 2>/dev/null || echo "{}")
  if ! echo "$remote_tags_json" | jq . &>/dev/null; then
    echo "Remote metadata tags file is invalid. Using an empty JSON object."
    remote_tags_json="{}"
  fi
  echo "Remote tags fetched."

  # 2. Extract tags from local metadata file.
  local local_tags_json
  local_tags_json=$(jq 'map_values(.tags // [])' "${METADATA_LOCAL_PATH}")
  echo "Local tags extracted."

  # 3. Merge local and remote tags. For each host, combine tags and remove duplicates.
  local merged_tags_json
  merged_tags_json=$(jq -n --argjson local "$local_tags_json" --argjson remote "$remote_tags_json" \
    '$remote as $r | $local | reduce ($r | keys_unsorted[]) as $key (.; .[$key] = ((.[$key] // []) + ($r[$key] // []) | unique))')
  echo "Tags merged."

  # 4. Update the local metadata.json file with the merged tags.
  echo "Updating local metadata file..."
  local temp_metadata
  temp_metadata=$(mktemp)
  # This command updates tags for existing entries and adds new entries if they don't exist.
  jq --argjson merged "$merged_tags_json" \
    'reduce ($merged | keys_unsorted[]) as $key (.;
      .[$key] |= . // {} | # Create entry if it does not exist
      .[$key].tags = $merged[$key]
    )' "${METADATA_LOCAL_PATH}" > "$temp_metadata" && mv "$temp_metadata" "${METADATA_LOCAL_PATH}"
  echo "Local metadata file updated."

  # 5. Update the remote Gist with the merged tags.
  push_content_to_gist "$merged_tags_json" "${METADATA_GIST_FILENAME}"
}


# --- Main Execution ---

main() {
  # Handle 'set-gist' command
  if [[ "${1:-}" == "set-gist" ]]; then
    if [[ -z "${2:-}" ]]; then
      die "Usage: $0 set-gist <GIST_ID>"
    fi
    set_gist_id "$2"
    exit 0
  fi

  # For sync operation
  check_dependencies
  check_gh_auth
  load_or_prompt_gist_id

  echo "Starting sync process for Gist ID: ${GIST_ID}"

  sync_ssh_config
  sync_metadata_tags

  echo "Sync process completed successfully."
}

# Run the main function with all script arguments
main "$@"